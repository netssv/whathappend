{
    "manifest_version": 3,
    "name": "WhatHappened Terminal",
    "version": "2.0.0",
    "description": "An educational side panel terminal. Learn how to diagnose DNS, SSL, and email infrastructure using simple, guided commands.",
    "permissions": [
        "activeTab",
        "tabs",
        "sidePanel",
        "storage",
        "clipboardRead"
    ],
    "host_permissions": [
        "https://dns.google/*",
        "https://rdap.org/*",
        "https://crt.sh/*",
        "https://*/*",
        "http://*/*"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    },
    "side_panel": {
        "default_path": "terminal.html"
    },
    "action": {
        "default_title": "WhatHappened — Web Infrastructure Triage",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}